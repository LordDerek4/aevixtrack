generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum SubscriptionType {
  PAID
  FREE_TRIAL
  FREEMIUM
}

enum ReminderOffset {
  ONE_DAY
  THREE_DAYS
  SEVEN_DAYS
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  ARCHIVED
}

enum NotificationType {
  RENEWAL_REMINDER
  TRIAL_ENDING
  GENERAL
}

enum PlanTier {
  STARTER
  PRO
  BUSINESS
}

model User {
  id            String         @id
  email         String         @unique
  fullName      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  stripeCustomerId     String?        @unique
  stripeSubscriptionId String?        @unique
  stripePriceId        String?
  planTier             PlanTier       @default(STARTER)
  subscriptions        Subscription[]
  reminders            Reminder[]
  settings             Settings?
  notifications        Notification[]

  @@map("users")
}

model Subscription {
  id               String             @id @default(uuid()) @db.Uuid
  userId           String
  serviceName      String
  category         String
  cost             Decimal            @db.Decimal(10, 2)
  billingCycle     BillingCycle       @default(MONTHLY)
  renewalDate      DateTime
  notes            String?
  subscriptionType SubscriptionType   @default(PAID)
  status           SubscriptionStatus @default(ACTIVE)
  isFreeTrial      Boolean            @default(false)
  trialEndsAt      DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  reminders        Reminder[]
  notifications    Notification[]

  @@index([userId, renewalDate])
  @@map("subscriptions")
}

model Reminder {
  id             String         @id @default(uuid()) @db.Uuid
  userId         String
  subscriptionId String         @db.Uuid
  offset         ReminderOffset
  emailEnabled   Boolean        @default(true)
  sentAt         DateTime?
  createdAt      DateTime       @default(now())
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription   Subscription   @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, offset])
  @@index([userId])
  @@map("reminders")
}

model Settings {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique
  currency        String   @default("USD")
  darkMode        Boolean  @default(true)
  emailReminders  Boolean  @default(true)
  reminderOffsets String[] @default(["ONE_DAY", "THREE_DAYS", "SEVEN_DAYS"])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("settings")
}

model Notification {
  id             String           @id @default(uuid()) @db.Uuid
  userId         String
  subscriptionId String?          @db.Uuid
  type           NotificationType @default(GENERAL)
  message        String
  read           Boolean          @default(false)
  createdAt      DateTime         @default(now())
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription   Subscription?    @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}
